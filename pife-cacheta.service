[Unit]
Description=Pife/Cacheta Game Server
After=network.target

[Service]
Type=simple
User=mizael-rocha
Group=mizael-rocha
WorkingDirectory=/home/mizael-rocha/CashBox/fontes/pife-cacheta
ExecStart=/home/mizael-rocha/.nvm/versions/node/v22.16.0/bin/npm run dev
Restart=on-failure
Environment=NODE_ENV=production
Environment=PATH=/home/mizael-rocha/.nvm/versions/node/v22.16.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
